# Sao chép thành .env và điền giá trị thật. KHÔNG commit .env.
# Pipeline lab này chạy hoàn toàn từ data/sample/ nên không bắt buộc các biến dưới,
# nhưng đây là các biến bạn SẼ cần khi nối nguồn thật.

# --- PostgreSQL (nguồn ticket helpdesk) ---
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=helpdesk
PG_USER=readonly
PG_PASSWORD=change-me

# --- Jira / CRM API ---
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_API_TOKEN=change-me
JIRA_RATE_LIMIT_PER_MIN=50

# --- Vector store (khi thay bằng store thật, ví dụ Qdrant/pgvector) ---
VECTOR_STORE_URL=http://localhost:6333
VECTOR_COLLECTION=kb_documents

# --- Thời điểm "now" của lab (để reproduce run_id). Bỏ trống = dùng mặc định trong config.py ---
# LAB_NOW=2026-02-10T14:35:00+00:00
